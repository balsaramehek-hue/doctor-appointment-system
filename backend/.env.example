# ============================================================
# MediCare Backend — Environment Configuration (Render)
# ============================================================

# Server
PORT=10000
NODE_ENV=production

# MongoDB Atlas connection string
MONGODB_URI=your_mongodb_atlas_uri

# JWT
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# Frontend origin (Netlify site URL) — required for CORS + cookies
CLIENT_URL=https://smart-healthcare-hospital.netlify.app

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Email (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=MediCare Hospital <no-reply@medicarehospital.com>

# File upload
MAX_FILE_SIZE=5242880
